JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque_por_uma_chave_refresh_forte_em_producao
JWT_REFRESH_EXPIRES_IN=1d
JWT_PORTARIA_CUTOFF_1=06:00
JWT_PORTARIA_CUTOFF_2=18:00

# Mail (SMTP)
